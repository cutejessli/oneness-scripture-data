{"book":"Numbers","book_id":"numbers","chapter":1,"layer":"mystical_translation","relationship_to_restored_text":"Interpretive contemplative layer aligned by verse. This does not replace the source-audited restored translation.","verses":[{"verse":1,"mystical_translation":"YHWH speaks in the wilderness after liberation."},{"verse":2,"mystical_translation":"The people are counted by name, clan, and household."},{"verse":3,"mystical_translation":"Those able to go out with the host are organized."},{"verse":4,"mystical_translation":"Each tribe brings a recognized leader."},{"verse":5,"mystical_translation":"Reuben's leader is named."},{"verse":6,"mystical_translation":"Simeon's leader is named."},{"verse":7,"mystical_translation":"Judah's leader is named."},{"verse":8,"mystical_translation":"Issachar's leader is named."},{"verse":9,"mystical_translation":"Zebulun's leader is named."},{"verse":10,"mystical_translation":"Ephraim and Manasseh are represented."},{"verse":11,"mystical_translation":"Benjamin's leader is named."},{"verse":12,"mystical_translation":"Dan's leader is named."},{"verse":13,"mystical_translation":"Asher's leader is named."},{"verse":14,"mystical_translation":"Gad's leader is named."},{"verse":15,"mystical_translation":"Naphtali's leader is named."},{"verse":16,"mystical_translation":"The summoned leaders stand for Israel's thousands."},{"verse":17,"mystical_translation":"Moses and Aaron receive the named men."},{"verse":18,"mystical_translation":"The congregation registers by lineage and name."},{"verse":19,"mystical_translation":"The wilderness census follows YHWH's command."},{"verse":20,"mystical_translation":"Reuben is counted for the host."},{"verse":21,"mystical_translation":"Reuben's number is recorded."},{"verse":22,"mystical_translation":"Simeon is counted."},{"verse":23,"mystical_translation":"Simeon's number is recorded."},{"verse":24,"mystical_translation":"Gad is counted."},{"verse":25,"mystical_translation":"Gad's number is recorded."},{"verse":26,"mystical_translation":"Judah is counted."},{"verse":27,"mystical_translation":"Judah's number is recorded."},{"verse":28,"mystical_translation":"Issachar is counted."},{"verse":29,"mystical_translation":"Issachar's number is recorded."},{"verse":30,"mystical_translation":"Zebulun is counted."},{"verse":31,"mystical_translation":"Zebulun's number is recorded."},{"verse":32,"mystical_translation":"Ephraim is counted."},{"verse":33,"mystical_translation":"Ephraim's number is recorded."},{"verse":34,"mystical_translation":"Manasseh is counted."},{"verse":35,"mystical_translation":"Manasseh's number is recorded."},{"verse":36,"mystical_translation":"Benjamin is counted."},{"verse":37,"mystical_translation":"Benjamin's number is recorded."},{"verse":38,"mystical_translation":"Dan is counted."},{"verse":39,"mystical_translation":"Dan's number is recorded."},{"verse":40,"mystical_translation":"Asher is counted."},{"verse":41,"mystical_translation":"Asher's number is recorded."},{"verse":42,"mystical_translation":"Naphtali is counted."},{"verse":43,"mystical_translation":"Naphtali's number is recorded."},{"verse":44,"mystical_translation":"Twelve leaders witness the counting."},{"verse":45,"mystical_translation":"The host-age population is gathered into one total."},{"verse":46,"mystical_translation":"The number of the host is recorded."},{"verse":47,"mystical_translation":"Levi is not included in the military census."},{"verse":48,"mystical_translation":"YHWH speaks a different vocation for Levi."},{"verse":49,"mystical_translation":"Levi is set apart from this count."},{"verse":50,"mystical_translation":"Levites carry, guard, and serve the dwelling-place."},{"verse":51,"mystical_translation":"They take it down and raise it according to the journey."},{"verse":52,"mystical_translation":"Israel camps by standard and company."},{"verse":53,"mystical_translation":"Levi forms a protective ring around the dwelling-place."},{"verse":54,"mystical_translation":"Israel does as YHWH commanded."}],"contemplative_note":"Numbers begins by naming and ordering a wilderness people. The census is not a ranking of souls: those outside the military count remain fully within covenant life, while Levi serves a different center."}