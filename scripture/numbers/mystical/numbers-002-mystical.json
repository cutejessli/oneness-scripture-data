{"book":"Numbers","book_id":"numbers","chapter":2,"layer":"mystical_translation","relationship_to_restored_text":"Interpretive contemplative layer aligned by verse. This does not replace the source-audited restored translation.","verses":[{"verse":1,"mystical_translation":"YHWH orders the camp around Presence."},{"verse":2,"mystical_translation":"Each household keeps its sign while the tent remains central."},{"verse":3,"mystical_translation":"Judah camps toward sunrise."},{"verse":4,"mystical_translation":"Judah's host is counted."},{"verse":5,"mystical_translation":"Issachar camps beside Judah."},{"verse":6,"mystical_translation":"Issachar's host is counted."},{"verse":7,"mystical_translation":"Zebulun completes the eastern camp."},{"verse":8,"mystical_translation":"Zebulun's host is counted."},{"verse":9,"mystical_translation":"The eastern camp moves first."},{"verse":10,"mystical_translation":"Reuben camps to the south."},{"verse":11,"mystical_translation":"Reuben's host is counted."},{"verse":12,"mystical_translation":"Simeon camps beside Reuben."},{"verse":13,"mystical_translation":"Simeon's host is counted."},{"verse":14,"mystical_translation":"Gad completes the southern camp."},{"verse":15,"mystical_translation":"Gad's host is counted."},{"verse":16,"mystical_translation":"The southern camp moves second."},{"verse":17,"mystical_translation":"The dwelling-place moves in the midst."},{"verse":18,"mystical_translation":"Ephraim camps to the west."},{"verse":19,"mystical_translation":"Ephraim's host is counted."},{"verse":20,"mystical_translation":"Manasseh camps beside Ephraim."},{"verse":21,"mystical_translation":"Manasseh's host is counted."},{"verse":22,"mystical_translation":"Benjamin completes the western camp."},{"verse":23,"mystical_translation":"Benjamin's host is counted."},{"verse":24,"mystical_translation":"The western camp moves third."},{"verse":25,"mystical_translation":"Dan camps to the north."},{"verse":26,"mystical_translation":"Dan's host is counted."},{"verse":27,"mystical_translation":"Asher camps beside Dan."},{"verse":28,"mystical_translation":"Asher's host is counted."},{"verse":29,"mystical_translation":"Naphtali completes the northern camp."},{"verse":30,"mystical_translation":"Naphtali's host is counted."},{"verse":31,"mystical_translation":"The northern camp moves last."},{"verse":32,"mystical_translation":"The full host total is remembered."},{"verse":33,"mystical_translation":"Levi remains outside the military count."},{"verse":34,"mystical_translation":"Israel camps and journeys as commanded."}],"contemplative_note":"Numbers 2 imagines a moving sanctuary-community: distinct households, ordered movement, and Presence at the center. Order serves belonging; it does not create superior tribes."}